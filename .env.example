# OpenAI-compatible API
OPENAI_BASE_URL=https://your-api-base-url/v1
OPENAI_API_KEY=sk-xxxxxx
OPENAI_MODEL=gpt-4o

# Root directory of your persona/memory project (contains PERSONA.md, MEMORY.md, etc.)
CASS_ROOT=/home/youruser/your-persona-project

# Root directory of this wechat-ai-persona project
WEIXIN_ROOT=/home/youruser/wechat-ai-persona

# Persona identity (used in system prompt)
PERSONA_NAME=Cass
USER_NAME=User

# Memory DB (SQLite, used by memory/memory_store.py)
MEMORY_DB_PATH=./data/memory.db
MAX_HISTORY=40
